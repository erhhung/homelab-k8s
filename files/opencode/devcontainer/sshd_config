# /etc/ssh/sshd_config.d/10-devcontainer.conf

# this file is templated--substitutions will
# be performed by envsubst in the Dockerfile

Port ${SSH_PORT}
ListenAddress 0.0.0.0
# host key will be generated by init container
HostKey /etc/ssh/host_keys/ssh_host_ed25519_key

PubkeyAuthentication yes
PasswordAuthentication no
KbdInteractiveAuthentication no

PermitRootLogin no
AllowUsers ${DEV_USER}
# authorized keys file will be a pod volume mount
AuthorizedKeysFile /etc/ssh/authorized_keys/%u.pub

X11Forwarding no
PermitTunnel no

# VSCode remote SSH uses SSH forwarding
# to communicate with the VSCode server
AllowTcpForwarding yes
